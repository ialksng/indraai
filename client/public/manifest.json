{
  "manifest_version": 3,
  "name": "Indra Web Agent",
  "version": "1.0",
  "description": "An autonomous multimodal web agent.",
  "permissions": [
    "tabs",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  }
}